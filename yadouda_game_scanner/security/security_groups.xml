<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="res.groups.privilege" id="res_groups_privilege_game_scanner">
        <field name="name">Game Scanner</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="group_game_operator" model="res.groups">
        <field name="name">Operator: Scan tickets</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_game_scanner"/>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="comment">Users who can scan tickets for assigned games.</field>
    </record>

    <record id="group_game_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_game_scanner"/>
        <field name="comment">Users who can manage game configurations and view all consumption.</field>
        <field name="implied_ids" eval="[(4, ref('group_game_operator'))]"/>
    </record>

</odoo>
