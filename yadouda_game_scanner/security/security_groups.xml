<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Create Game Operator Group -->
        <record id="group_game_operator" model="res.groups">
            <field name="name">Game Operator</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Users who can scan tickets for specific games</field>
        </record>

        <!-- Create Game Manager Group (optional) -->
        <record id="group_game_manager" model="res.groups">
            <field name="name">Game Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="comment">Users who can manage game configurations</field>
            <field name="implied_ids" eval="[(4, ref('group_game_operator'))]"/>
        </record>
    </data>
</odoo>
