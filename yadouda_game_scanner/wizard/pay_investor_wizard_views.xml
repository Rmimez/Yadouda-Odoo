<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pay_investor_wizard_form" model="ir.ui.view">
        <field name="name">yadouda.game.pay.investor.wizard.form</field>
        <field name="model">yadouda.game.pay.investor.wizard</field>
        <field name="arch" type="xml">
            <form string="Pay investor">
                <group>
                    <field name="game_id" invisible="1"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                </group>
                <group string="Lines in date range" invisible="not line_ids">
                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="date"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="unit_price"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </group>
                <group string="Totals" invisible="not line_ids">
                    <group>
                        <field name="total_quantity" readonly="1"/>
                    </group>
                    <group>
                        <field name="total_amount" readonly="1"/>
                        <field name="currency_id" readonly="1" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_bill" string="Create vendor bill" type="object" class="btn-primary" invisible="not line_ids"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
