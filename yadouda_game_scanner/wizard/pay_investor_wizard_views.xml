<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pay_investor_wizard_form" model="ir.ui.view">
        <field name="name">yadouda.game.pay.investor.wizard.form</field>
        <field name="model">yadouda.game.pay.investor.wizard</field>
        <field name="arch" type="xml">
            <form string="Pay investor" class="o_pay_investor_wizard">
                <sheet>
                    <field name="game_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <!-- Header: game and purpose -->
                    <div class="mb-4">
                        <h4 class="mb-1">
                            <i class="fa fa-file-text-o text-primary me-2"/>
                            Create vendor bill for investor
                        </h4>
                        <p class="text-muted mb-0 small">
                            Select the date range to include ticket lines. The bill will use the game's revenue percentage.
                        </p>
                    </div>

                    <!-- Date range -->
                    <group string="Date range" class="mb-4">
                        <group>
                            <field name="date_start" placeholder="Start date"/>
                            <field name="date_end" placeholder="End date"/>
                        </group>
                    </group>

                    <!-- Lines in range -->
                    <group string="Ticket lines in range" invisible="not line_ids" class="mb-3">
                        <field name="line_ids" nolabel="1" readonly="1" class="o_wizard_line_list">
                            <list create="0" delete="0" edit="0" class="o_list_table">
                                <field name="date"/>
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="True"/>
                            </list>
                        </field>
                    </group>

                    <!-- Empty state -->
                    <div class="alert alert-info mb-0" role="alert" invisible="line_ids">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>No lines in this range.</strong> Adjust the start and end dates to include bulk ticket entries, then create the bill.
                    </div>

                    <!-- Totals summary -->
                    <group string="Summary" invisible="not line_ids" class="mt-4">
                        <group>
                            <field name="total_quantity" string="Total quantity" readonly="1" class="fw-bold"/>
                        </group>
                        <group>
                            <field name="total_amount" string="Total amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}" class="fw-bold"/>
                        </group>
                    </group>
                </sheet>
                <footer class="d-flex justify-content-end gap-2 border-top pt-3 mt-3">
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    <button name="action_create_bill" string="Create vendor bill" type="object" class="btn btn-primary" invisible="not line_ids">
                        <i class="fa fa-check me-1"/> Create vendor bill
                    </button>
                </footer>
            </form>
        </field>
    </record>
</odoo>
