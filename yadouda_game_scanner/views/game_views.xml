<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_yadouda_game_form" model="ir.ui.view">
        <field name="name">yadouda.game.form</field>
        <field name="model">yadouda.game</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                            name="action_open_scanner"
                            string="Start Scanning"
                            type="object"
                            class="btn-primary"
                            groups="yadouda_game_scanner.group_game_operator"
                            invisible="uid not in responsible_user_ids"/>
                    <button
                            name="action_pay_investor"
                            string="Pay investor"
                            type="object"
                            class="btn-secondary"
                            groups="yadouda_game_scanner.group_game_manager"
                            invisible="not investor_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_investor_bills" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                groups="yadouda_game_scanner.group_game_manager"
                                invisible="investor_bill_count == 0">
                            <field name="investor_bill_count" widget="statinfo" string="Bills"/>
                        </button>
                    </div>
                    <group>
                        <field name="image_1920" widget="image" class="oe_avatar"
                               options="{'preview_image': 'image_1920', 'size': [300, 300]}" no_label="1"/>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <group string="Investor"
                           groups="yadouda_game_scanner.group_game_manager">
                        <field name="investor_id"/>
                        <field name="revenue_percentage" string="Revenue (%)"/>
                    </group>

                    <group string="Assigned Operators"
                           groups="yadouda_game_scanner.group_game_manager">
                        <field name="responsible_user_ids" widget="many2many_tags"/>
                    </group>

                    <group string="Today's Consumption">
                        <field name="today_total_tickets"/>
                    </group>

                    <notebook>
                        <page string="Today's Records">
                            <field name="today_consumption_ids" mode="kanban" options="{'no_create': True}"/>
                        </page>
                        <page string="All scanned tickets">
                            <field name="consumption_ids" nolabel="1" options="{'no_create': True}">
                                <list create="0" delete="0" edit="0">
                                    <field name="ticket_code"/>
                                    <field name="ticket_count"/>
                                    <field name="operator_id"/>
                                    <field name="date"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Bulk ticket entry">
                            <group>
                                <p class="text-muted mb-0">Add lines with date, ticket/product and quantity. Total quantity and amount are shown below.</p>
                            </group>
                            <field name="ticket_line_ids" nolabel="1">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="date"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                            <group string="Totals" class="mt-3">
                                <group>
                                    <field name="total_bulk_quantity" string="Total quantity" readonly="1"/>
                                </group>
                                <group>
                                    <field name="total_bulk_amount" string="Total amount" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" readonly="1" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_yadouda_game_kanban" model="ir.ui.view">
        <field name="name">yadouda.game.kanban</field>
        <field name="model">yadouda.game</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="code"/>
                <field name="image_128"/>
                <field name="today_total_tickets"/>
                <field name="active"/>
                <field name="responsible_user_ids"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="o_kanban_aside_full">
                            <field name="image_128" class="o_kanban_image_fill w-100" widget="image"
                                   options="{'img_class': 'object-fit-cover'}" alt="Game image"/>
                        </aside>
                        <main class="ps-2 d-flex flex-column justify-content-center">
                            <field name="name" class="fw-bold"/>
                            <div class="text-muted small">
                                <field name="code"/>
                            </div>
                            <div class="mt-1">
                                <span class="badge text-bg-secondary">Today:
                                    <field name="today_total_tickets"/>
                                </span>
                            </div>
                            <button name="action_open_scanner" type="object" class="btn btn-primary btn-sm mt-2"
                                    string="Start Scanning" groups="yadouda_game_scanner.group_game_operator"
                                    invisible="uid not in responsible_user_ids"/>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_yadouda_game_list" model="ir.ui.view">
        <field name="name">yadouda.game.list</field>
        <field name="model">yadouda.game</field>
        <field name="arch" type="xml">
            <list>
                <field name="image_128" widget="image" options="{'size': [64, 64]}"/>
                <field name="name"/>
                <field name="code"/>
                <field name="today_total_tickets"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_yadouda_game_search" model="ir.ui.view">
        <field name="name">yadouda.game.search</field>
        <field name="model">yadouda.game</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter
                        name="my_games"
                        string="My Games"
                        domain="[('responsible_user_ids', 'in', [uid])]"/>
            </search>
        </field>
    </record>
</odoo>
