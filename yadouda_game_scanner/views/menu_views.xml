<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_yadouda_games" model="ir.actions.act_window">
        <field name="name">Games</field>
        <field name="res_model">yadouda.game</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_my_games': 1}</field>
    </record>

    <record id="action_yadouda_consumption" model="ir.actions.act_window">
        <field name="name">Ticket Consumption</field>
        <field name="res_model">ticket.consumption</field>
        <field name="view_mode">list,graph,pivot</field>
    </record>

    <menuitem
            id="menu_yadouda_games"
            name="Games"
            sequence="10"
            web_icon="yadouda_game_scanner,static/description/icon.png"/>

    <menuitem
            id="menu_yadouda_game_list"
            name="My Games"
            parent="menu_yadouda_games"
            action="action_yadouda_games"
            groups="yadouda_game_scanner.group_game_operator"
            sequence="10"/>

    <menuitem
            id="menu_yadouda_consumption_reports"
            name="Consumption Reports"
            parent="menu_yadouda_games"
            action="action_yadouda_consumption"
            groups="yadouda_game_scanner.group_game_manager"
            sequence="20"/>


</odoo>
